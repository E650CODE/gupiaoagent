# ===== 应用 =====
APP_NAME=gupiaoagent
APP_ENV=dev
APP_HOST=127.0.0.1
APP_PORT=8000

# ===== 日志 =====
LOG_LEVEL=INFO
LOG_DIR=./logs

# ===== 数据 =====
DATA_DIR=./data
SQLITE_PATH=./data/app.db

# ===== Redis =====
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# ===== LLM 配置加密密钥 =====
# 首次启动若为空将自动生成并写回 .env；生产请妥善保管
LLM_CONFIG_SECRET=

# ===== LLM 配置文件 =====
LLM_CONFIG_PATH=./data/llm_config.json

# ===== CORS 允许来源 =====
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ===== Agent 调度 =====
AGENT_TIMEOUT_SECONDS=60
AGENT_MAX_RETRY=3

# ===== 合规声明 =====
DISCLAIMER=本内容仅为数据分析学习，不构成投资建议
